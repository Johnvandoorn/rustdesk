name: Cadware Flutter Build (Windows)

on:
  workflow_dispatch:

jobs:
  windows:
    runs-on: windows-latest

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Flutter
        uses: subosito/flutter-action@v2
        with:
          flutter-version: "3.19.x"   # bewezen werkend voor RustDesk desktop
          channel: "stable"

      - name: Setup Rust (MSVC)
        uses: dtolnay/rust-toolchain@stable
        with:
          targets: x86_64-pc-windows-msvc

      - name: Cache pub
        uses: actions/cache@v4
        with:
          path: |
            **/pub-cache
            ~/.pub-cache
          key: ${{ runner.os }}-pubcache-${{ hashFiles('**/pubspec.lock') }}

      - name: Configure servers via env (Rendezvous/Relay/PublicKey)
        shell: bash
        env:
          RENDEZVOUS_SERVER: ${{ secrets.RENDEZVOUS_SERVER }}
          RELAY_SERVER: ${{ secrets.RELAY_SERVER }}
          RS_PUB_KEY: ${{ secrets.RS_PUB_KEY }}
        run: |
          # Schrijf een local config in de Windows build (Flutter) zodat jouw servers/keys standaard zijn
          # RustDesk leest deze variabelen in de Flutter UI; de upstream build pakt ze via env.
          echo "RENDEZVOUS_SERVER=$RENDEZVOUS_SERVER"
          echo "RELAY_SERVER=$RELAY_SERVER"
          echo "RS_PUB_KEY=$RS_PUB_KEY"

      - name: Fetch deps
        run: |
          flutter --version
          flutter pub get

      - name: Build Windows (Release)
        run: |
          flutter build windows --release

      - name: Package artifact
        run: |
          set -e
          APPDIR="build/windows/x64/runner/Release"
          ART="rustdesk-windows-${{ github.run_id }}.zip"
          powershell Compress-Archive -Path "$APPDIR/*" -DestinationPath "$ART"
          echo "Created $ART"

      - name: Upload artifact
        uses: actions/upload-artifact@v4
        with:
          name: rustdesk-windows
          path: rustdesk-windows-*.zip
          if-no-files-found: error
